{
  "name": "forkoff",
  "version": "1.0.6",
  "description": "CLI tool for ForkOff - Connect your AI coding tools to mobile. Currently in waitlist - join at forkoff.app",
  "main": "dist/integration.js",
  "types": "dist/integration.d.ts",
  "homepage": "https://forkoff.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/Forkoff-app/forkoff-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Forkoff-app/forkoff-cli/issues",
    "email": "support@forkoff.app"
  },
  "bin": {
    "forkoff": "./dist/index.js"
  },
  "exports": {
    ".": {
      "require": "./dist/integration.js",
      "types": "./dist/integration.d.ts"
    },
    "./cli": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc -w"
  },
  "keywords": [
    "cli",
    "ai",
    "coding",
    "mobile",
    "claude",
    "forkoff",
    "waitlist"
  ],
  "author": {
    "name": "ForkOff",
    "email": "support@forkoff.app",
    "url": "https://forkoff.app"
  },
  "license": "Proprietary",
  "dependencies": {
    "axios": "^1.13.2",
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "commander": "^14.0.2",
    "cross-spawn": "^7.0.6",
    "inquirer": "^12.11.1",
    "node-machine-id": "^1.1.12",
    "ora": "^5.4.1",
    "qrcode-terminal": "^0.12.0",
    "socket.io-client": "^4.8.3",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.0.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
